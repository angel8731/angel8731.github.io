<view class="home-page">
  <view class="profile-card">
    <view class="avatar">👤</view>
    <view class="profile-main">
      <view class="user-name">{{user.name}}</view>
      <view class="user-phone">{{user.phone}}</view>
    </view>
    <view class="profile-actions">
      <text class="action-icon" bindtap="onTapNotice">🔔</text>
      <text class="action-icon" bindtap="onTapSearch">🔍</text>
    </view>
  </view>

  <view class="service-grid">
    <block wx:for="{{services}}" wx:key="name">
      <view class="service-item" style="background: {{item.bg}};" data-path="{{item.path}}" bindtap="goAction">
        <view class="service-icon">{{item.icon}}</view>
        <view class="service-name">{{item.name}}</view>
      </view>
    </block>
  </view>

  <view class="section-title-row">
    <text class="section-title">附近门店</text>
    <text class="section-more">›</text>
  </view>

  <view class="store-list">
    <block wx:for="{{stores}}" wx:key="name">
      <view class="store-card">
        <view class="store-top">
          <view class="store-photo">门店</view>
          <view class="store-summary">
            <view class="name-row">
              <text class="store-name">{{item.name}}</text>
              <text class="store-distance">{{item.distance}}</text>
            </view>
            <view class="store-sub">收费标准: {{item.price}}</view>
            <view class="status-row">
              <text class="status-label">洗车位状态：</text>
              <text class="badge badge-primary">🚘 {{item.total}}</text>
              <text class="badge">{{item.inUse}}</text>
            </view>
          </view>
        </view>

        <view class="store-bottom">
          <view class="address">📍 {{item.address}}</view>
          <button class="nav-btn" size="mini" data-index="{{index}}" bindtap="navigateStore">➤ 导航</button>
        </view>
      </view>
    </block>
  </view>
</view>
